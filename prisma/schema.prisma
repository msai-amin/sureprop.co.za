// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  AGENT
  LAWYER
  BOND
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PropertyStatus {
  ACTIVE
  SOLD
  UNDER_OFFER
}

enum LeadStatus {
  NEW
  CONTACTED
  VIEWING_SCHEDULED
  OFFER_MADE
  CLOSED
}

enum DocumentType {
  ID
  BANK_STATEMENT
  OFFER_TO_PURCHASE
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum AuditResourceType {
  LEAD
  DOCUMENT
  PROPERTY
  SUBSCRIPTION
}

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  role               UserRole
  verificationStatus VerificationStatus @default(PENDING)
  fullName           String?
  email              String             @unique
  phone              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  properties   Property[]
  leadsAsBuyer Lead[]        @relation("LeadBuyer")
  leadsAsAgent Lead[]        @relation("LeadAgent")
  documents    Document[]
  subscription Subscription?
  auditEvents  AuditLog[]    @relation("AuditActor")
}

model Property {
  id        String         @id @default(uuid()) @db.Uuid
  agentId   String         @db.Uuid
  title     String
  price     Decimal        @db.Decimal(14, 2)
  location  Json
  features  Json           @default("{}")
  status    PropertyStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  agent User   @relation(fields: [agentId], references: [id], onDelete: Restrict)
  leads Lead[]

  @@index([agentId])
  @@index([status])
}

model Lead {
  id         String     @id @default(uuid()) @db.Uuid
  propertyId String     @db.Uuid
  buyerId    String     @db.Uuid
  agentId    String     @db.Uuid
  status     LeadStatus @default(NEW)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer    User     @relation("LeadBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  agent    User     @relation("LeadAgent", fields: [agentId], references: [id], onDelete: Restrict)

  @@index([propertyId])
  @@index([buyerId])
  @@index([agentId])
  @@index([status, createdAt])
}

model Document {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  type        DocumentType
  storageUrl  String
  isEncrypted Boolean      @default(true)
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @db.Uuid
  tier               SubscriptionTier   @default(FREE)
  paystackCustomerId String?            @unique
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model AuditLog {
  id           String            @id @default(uuid()) @db.Uuid
  actorUserId  String            @db.Uuid
  action       String
  resourceType AuditResourceType
  resourceId   String?           @db.Uuid
  metadata     Json?
  createdAt    DateTime          @default(now())

  actor User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([resourceType, createdAt])
}
