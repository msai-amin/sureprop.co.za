# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: server-only (never expose to the browser or commit real keys)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Prisma: Dashboard → Connect → Postgres URI (or pooler). URL-encode special chars in password.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Apply schema: npx prisma migrate deploy

# Dev only: allow x-user-id + x-user-role headers instead of Supabase cookies (API testing)
# AUTH_HEADER_FALLBACK=true
