# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: server-only (never expose to the browser or commit real keys)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_VAULT_BUCKET=vault

# Prisma: Dashboard → Connect → Postgres URI (or pooler). URL-encode special chars in password.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Apply schema: npx prisma migrate deploy
#
# Verify Supabase vars: npm run check:env
#
# Vercel: add all of the above (incl. DATABASE_URL) under Project → Settings → Environment Variables
# for Production and Preview. Prisma client is generated on install via postinstall.

# Dev only: allow x-user-id + x-user-role headers instead of Supabase cookies (API testing)
# AUTH_HEADER_FALLBACK=true
#
# Supabase → Authentication → URL Configuration:
#   Site URL: https://your-production-domain (e.g. https://sureprop.co.za)
#   Redirect URLs: http://localhost:3000/auth/callback  https://your-domain/auth/callback
#
# Supabase → Authentication → Providers → Google: enable and set GCP OAuth client IDs.
